NODE_ENV=development
PORT=3000

DATABASE_URL="postgresql://mixin:mixin@localhost:5432/mixin_auth?schema=public"

AUTH_ISSUER=mixin-auth
AUTH_AUDIENCE=api
AUTH_JWT_KID=dev-kid

# Dev fallback (HS256). In production, prefer RS256 with:
# AUTH_JWT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# AUTH_JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
AUTH_JWT_HS_SECRET=dev-jwt-secret

REFRESH_TOKEN_PEPPER=dev-refresh-pepper-1234

# Comma separated list.
CORS_ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match the callback URL configured in Google Cloud Console.
# Example: http://localhost:3000/v1/auth/google/callback
GOOGLE_REDIRECT_URI=

